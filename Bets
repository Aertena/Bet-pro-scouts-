function Spinner({ size = 16 }) {
  return (
    <div style={{
      width: size, height: size, border: `2px solid var(--wire2)`,
      borderTopColor: "var(--gold)", borderRadius: "50%",
      animation: "spin 0.7s linear infinite", flexShrink: 0,
    }} />
  );
}

function FormDot({ result }) {
  const colors = { W: "#39d353", D: "#d4a843", L: "#e53935" };
  return (
    <div style={{
      width: 22, height: 22, borderRadius: "50%", background: colors[result] || "#333",
      display: "flex", alignItems: "center", justifyContent: "center",
      fontSize: 10, fontWeight: 700, color: "#000", fontFamily: "var(--font-mono)",
    }}>{result}</div>
  );
}

function ImpactBadge({ impact }) {
  const map = { high: ["#e53935", "#7f1d1d"], medium: ["#d4a843", "#3d2e0a"], low: ["#4d6480", "#131c27"] };
  const [fg, bg] = map[impact] || map.low;
  return (
    <span style={{ background: bg, color: fg, border: `1px solid ${fg}`, fontSize: 9, padding: "2px 6px", fontFamily: "var(--font-mono)", textTransform: "uppercase", letterSpacing: 1 }}>
      {impact}
    </span>
  );
}

function ConfidenceMeter({ level }) {
  const map = { high: 3, medium: 2, low: 1 };
  const n = map[level] || 1;
  const colors = { high: "var(--lime)", medium: "var(--gold)", low: "var(--red)" };
  return (
    <div style={{ display: "flex", gap: 3 }}>
      {[1, 2, 3].map(i => (
        <div key={i} style={{ width: 8, height: 8, background: i <= n ? colors[level] : "var(--wire)", borderRadius: 2 }} />
      ))}
    </div>
  );
}

