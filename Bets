// ─── BET SLIP ─────────────────────────────────────────────────────────────
function BetSlip({ picks, onResearch, onRemove, stake, onStakeChange }) {
  if (picks.length === 0) return null;
  const totalOdds = picks.reduce((acc, p) => acc * p.odds, 1);
  const payout = stake * totalOdds;
  const profit = payout - stake;

  return (
    <div style={{ background: "var(--ink2)", border: "1px solid var(--gold3)", marginTop: 24 }}>
      <div style={{ background: "var(--ink3)", padding: "12px 16px", display: "flex", justifyContent: "space-between", alignItems: "center", borderBottom: "1px solid var(--wire2)" }}>
        <div style={{ fontFamily: "var(--font-head)", fontSize: 20, letterSpacing: 2, color: "var(--gold)" }}>
          🎫 ACCUMULATOR SLIP
        </div>
        <div style={{ fontFamily: "var(--font-mono)", fontSize: 11, color: "var(--text3)" }}>
          {picks.length} leg{picks.length !== 1 ? "s" : ""}
        </div>
      </div>

      <div style={{ padding: 16, display: "flex", flexDirection: "column", gap: 10 }}>
        {picks.map((p, i) => (
          <div key={p.id} style={{ display: "flex", gap: 10, alignItems: "center", cursor: "pointer" }} onClick={() => onResearch(p)}>
            <div style={{ fontFamily: "var(--font-head)", fontSize: 22, color: "var(--text3)", minWidth: 20 }}>{i + 1}</div>
            <div style={{ flex: 1, background: "var(--ink3)", padding: "8px 12px" }}>
              <div style={{ fontFamily: "var(--font-head)", fontSize: 14, letterSpacing: 0.5 }}>{p.match}</div>
              <div style={{ display: "flex", gap: 8, marginTop: 2 }}>
                <span style={{ fontFamily: "var(--font-mono)", fontSize: 10, color: "var(--sky)" }}>{p.pick}</span>
                <span style={{ fontFamily: "var(--font-mono)", fontSize: 10, color: "var(--text3)" }}>·</span>
                <span style={{ fontFamily: "var(--font-mono)", fontSize: 10, color: "var(--text3)" }}>{p.league}</span>
              </div>
            </div>
            <div style={{ fontFamily: "var(--font-head)", fontSize: 20, color: "var(--gold2)", minWidth: 40, textAlign: "right" }}>
              {p.odds}
            </div>
            <button
              onClick={e => { e.stopPropagation(); onRemove(p.id); }}
              style={{ background: "none", border: "none", color: "var(--text3)", fontSize: 16, padding: "4px" }}
            >✕</button>
          </div>
        ))}
      </div>

      <div style={{ padding: "12px 16px", borderTop: "1px solid var(--wire2)", background: "var(--ink3)" }}>
        <div style={{ display: "flex", gap: 12, alignItems: "center", flexWrap: "wrap" }}>
          <div style={{ flex: 1, minWidth: 160 }}>
            <div style={{ fontFamily: "var(--font-mono)", fontSize: 10, color: "var(--text3)", textTransform: "uppercase", letterSpacing: 1, marginBottom: 6 }}>Stake (R)</div>
            <input
              type="number"
              value={stake}
              onChange={e => onStakeChange(Number(e.target.value))}
              style={{ background: "var(--ink)", border: "1px solid var(--wire2)", color: "var(--text)", padding: "8px 12px", width: "100%", fontSize: 16, fontFamily: "var(--font-mono)" }}
            />
          </div>
          <div style={{ display: "flex", gap: 16 }}>
            <div>
              <div style={{ fontFamily: "var(--font-mono)", fontSize: 9, color: "var(--text3)", textTransform: "uppercase", letterSpacing: 1 }}>Total Odds</div>
              <div style={{ fontFamily: "var(--font-head)", fontSize: 28, color: "var(--gold2)", letterSpacing: 1 }}>{totalOdds.toFixed(2)}</div>
            </div>
            <div>
              <div style={{ fontFamily: "var(--font-mono)", fontSize: 9, color: "var(--text3)", textTransform: "uppercase", letterSpacing: 1 }}>Potential Return</div>
              <div style={{ fontFamily: "var(--font-head)", fontSize: 28, color: "var(--lime)", letterSpacing: 1 }}>R{payout.toFixed(0)}</div>
            </div>
            <div>
              <div style={{ fontFamily: "var(--font-mono)", fontSize: 9, color: "var(--text3)", textTransform: "uppercase", letterSpacing: 1 }}>Profit</div>
              <div style={{ fontFamily: "var(--font-head)", fontSize: 28, color: "var(--lime)", letterSpacing: 1 }}>R{profit.toFixed(0)}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}

// ─── UPLOAD PANEL ─────────────────────────────────────────────────────────
function UploadPanel({ tolerance, onAddPick }) {
  const [files, setFiles] = useState([]);
  const [loading, setLoading] = useState(false);
  const [results, setResults] = useState([]);
  const [status, setStatus] = useState("");
  const [error, setError] = useState("");
  const ref = useRef();

  async function analyse() {
    if (!files.length) return;
    setLoading(true);
    setResults([]);
    setError("");
    setStatus("Reading your screenshots...");
    try {
      const allPicks = [];
      for (let i = 0; i < files.length; i++) {
        setStatus(`Analysing image ${i + 1} of ${files.length}...`);
        const b64 = await toBase64(files[i]);
        const mime = files[i].type || "image/jpeg";
        const raw = await callAI(IMAGE_SYSTEM, "Extract all betting predictions from this screenshot.", false, b64, mime);
        const parsed = parseJSON(raw);
        allPicks.push(...parsed);
      }
      // Filter by tolerance and odds ≤ 2.5
      const filtered = allPicks.filter(p => p.odds === null || p.odds <= 2.5);
      setResults(filtered);
      setStatus(`✅ Extracted ${allPicks.length} picks · ${filtered.length} within odds ≤ 2.5`);
    } catch (e) {
      setError("Could not analyse images: " + e.message);
    }
    setLoading(false);
  }

  const handleDrop = useCallback(e => {
    e.preventDefault();
    setFiles(Array.from(e.dataTransfer.files).filter(f => f.type.startsWith("image/")));
  }, []);

  return (
    <div>
      <div
        onDrop={handleDrop}
        onDragOver={e => e.preventDefault()}
        onClick={() => ref.current?.click()}
        style={{
          border: "2px dashed var(--wire2)", background: "var(--ink2)", padding: "32px 20px",
          textAlign: "center", cursor: "pointer", transition: "border-color 0.2s", marginBottom: 16,
        }}
      >
        <input ref={ref} type="file" accept="image/*" multiple style={{ display: "none" }}
          onChange={e => setFiles(Array.from(e.target.files))} />
        <div style={{ fontSize: 32, marginBottom: 10 }}>📸</div>
        <div style={{ fontFamily: "var(--font-head)", fontSize: 18, letterSpacing: 1, color: "var(--text2)" }}>
          Drop screenshots here or click to browse
        </div>
        <div style={{ fontFamily: "var(--font-mono)", fontSize: 11, color: "var(--text3)", marginTop: 6 }}>
          WhatsApp · Twitter/X · Facebook · Telegram · Any tipster screenshot
        </div>
      </div>

      {files.length > 0 && (
        <div style={{ display: "flex", flexWrap: "wrap", gap: 8, marginBottom: 16 }}>
          {files.map((f, i) => (
            <div key={i} style={{ background: "var(--ink3)", border: "1px solid var(--wire2)", padding: "6px 12px", fontFamily: "var(--font-mono)", fontSize: 11, color: "var(--text2)", display: "flex", gap: 8 }}>
              🖼 {f.name}
              <button onClick={e => { e.stopPropagation(); setFiles(files.filter((_, j) => j !== i)); }} style={{ background: "none", border: "none", color: "var(--text3)" }}>✕</button>
            </div>
          ))}
        </div>
      )}

      <button
        onClick={analyse}
        disabled={loading || !files.length}
        style={{
          background: loading || !files.length ? "var(--wire2)" : "var(--gold)",
          color: loading || !files.length ? "var(--text3)" : "#060a0f",
          border: "none", padding: "12px 24px", fontFamily: "var(--font-head)",
          fontSize: 16, letterSpacing: 2, marginBottom: 16, width: "100%",
        }}
      >
        {loading ? "ANALYSING..." : "ANALYSE SCREENSHOTS"}
      </button>

      {loading && (
        <div style={{ display: "flex", gap: 10, alignItems: "center", marginBottom: 16, fontFamily: "var(--font-mono)", fontSize: 12, color: "var(--gold)" }}>
          <Spinner /> {status}
        </div>
      )}
      {!loading && status && <div style={{ fontFamily: "var(--font-mono)", fontSize: 12, color: "var(--lime)", marginBottom: 16 }}>{status}</div>}
      {error && <div style={{ fontFamily: "var(--font-mono)", fontSize: 12, color: "var(--red)", marginBottom: 16 }}>⚠ {error}</div>}

      {results.length > 0 && (
        <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
          <div style={{ fontFamily: "var(--font-head)", fontSize: 16, letterSpacing: 1, color: "var(--text3)", marginBottom: 4 }}>
            EXTRACTED PREDICTIONS ({results.length})
          </div>
          {results.map((p, i) => (
            <div key={i} style={{ background: "var(--ink2)", border: "1px solid var(--wire2)", padding: "14px 16px" }}>
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", gap: 10 }}>
                <div style={{ flex: 1 }}>
                  <div style={{ fontFamily: "var(--font-head)", fontSize: 16, letterSpacing: 0.5 }}>{p.match || "Unknown Match"}</div>
                  <div style={{ fontFamily: "var(--font-mono)", fontSize: 10, color: "var(--text3)", margin: "3px 0 6px" }}>
                    {p.source} · {p.tipster || "Anonymous"} · {p.league || p.sport}
                  </div>
                  <div style={{ display: "inline-block", background: "var(--sky2)", padding: "4px 10px", fontSize: 12, color: "var(--sky)", fontWeight: 600, marginBottom: 6 }}>{p.pick}</div>
                  {p.brief && <div style={{ fontSize: 12, color: "var(--text3)" }}>{p.brief}</div>}
                </div>
                <div style={{ textAlign: "right", flexShrink: 0 }}>
                  <div style={{ fontFamily: "var(--font-head)", fontSize: 26, color: "var(--gold2)" }}>{p.odds || "?"}</div>
                  {p.amount && <div style={{ fontFamily: "var(--font-mono)", fontSize: 10, color: "var(--lime)" }}>R{p.amount.toLocaleString()}</div>}
                </div>
              </div>
              <button
                onClick={() => onAddPick({ ...p, id: `img-${i}`, tipsters: 1, kickoff: "TBD", sources: [p.source], confidence: p.confidence || "medium", brief: p.brief || p.pick })}
                style={{ marginTop: 8, background: "var(--gold)", color: "#060a0f", border: "none", padding: "6px 14px", fontFamily: "var(--font-head)", fontSize: 13, letterSpacing: 1 }}
              >
                + ADD TO SLIP
              </button>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

// ─── MAIN APP ─────────────────────────────────────────────────────────────
export default function BetScoutPro() {
  const [tab, setTab] = useState("scout");
  const [sport, setSport] = useState("All Sports");
  const [league, setLeague] = useState("All Leagues");
  const [tolerance, setTolerance] = useState(3);
  const [loading, setLoading] = useState(false);
  const [status, setStatus] = useState("");
  const [picks, setPicks] = useState([]);
  const [slip, setSlip] = useState([]);
  const [researching, setResearching] = useState(null);
  const [error, setError] = useState("");
  const [stake, setStake] = useState(1000);

  const scoutStatuses = [
    "Scanning tipster sites...",
    "Searching Twitter predictions...",
    "Checking Reddit r/SoccerBetting...",
    "Crawling sports forums...",
    "Cross-referencing odds...",
    "Filtering by your tolerance...",
    "Building intelligence report...",
  ];

  async function scout() {
    setLoading(true);
    setPicks([]);
    setError("");
    let si = 0;
    setStatus(scoutStatuses[0]);
    const iv = setInterval(() => {
      si = (si + 1) % scoutStatuses.length;
      setStatus(scoutStatuses[si]);
    }, 2200);

    const toleranceDesc = {
      1: "Only the safest favourites, single outcomes only",
      2: "Conservative — strong favourites, team to win or BTTS",
      3: "Balanced — good value bets, avoid big upsets",
      4: "Aggressive — higher risk picks with good evidence",
      5: "High risk — value bets including unlikely outcomes",
    }[tolerance];

    try {
      const raw = await callAI(
        SCOUT_SYSTEM,
        `Today's date: ${new Date().toLocaleDateString("en-ZA", { weekday: "long", day: "numeric", month: "long", year: "numeric" })}. Scout betting predictions for: Sport: ${sport}, League: ${league}. User risk tolerance: ${toleranceDesc}. Max odds per pick: 2.5. Search multiple sources and return 6-10 quality picks.`,
        true
      );
      clearInterval(iv);
      const data = parseJSON(raw);
      const valid = data.filter(p => p.odds && p.odds <= 2.5);
      setPicks(valid);
      setStatus(`✅ Scouted ${valid.length} picks with odds ≤ 2.5 from the web`);
    } catch (e) {
      clearInterval(iv);
      setError("Scouting failed: " + e.message);
      setStatus("");
    }
    setLoading(false);
  }

  function addToSlip(pick) {
    if (!slip.find(s => s.id === pick.id)) setSlip(prev => [...prev, pick]);
  }

  function removeFromSlip(id) {
    setSlip(prev => prev.filter(p => p.id !== id));
  }

  const inSlipIds = new Set(slip.map(p => p.id));

  return (
    <>
      <style>{G}</style>
      <style>{`
        @keyframes spin { to { transform: rotate(360deg); } }
        @keyframes fadeUp { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.4; } }
      `}</style>

      {researching && <ResearchModal pick={researching} onClose={() => setResearching(null)} key={researching.id} />}

      <div style={{ maxWidth: 860, margin: "0 auto", padding: "20px 14px" }}>

        {/* HEADER */}
        <div style={{ marginBottom: 28, borderBottom: "1px solid var(--wire)", paddingBottom: 20 }}>
          <div style={{ display: "flex", alignItems: "center", gap: 14, marginBottom: 8 }}>
            <div style={{
              width: 48, height: 48, background: "var(--gold)", display: "flex", alignItems: "center",
              justifyContent: "center", fontFamily: "var(--font-head)", fontSize: 22, color: "#060a0f", letterSpacing: 2,
            }}>BS</div>
            <div>
              <div style={{ fontFamily: "var(--font-head)", fontSize: 36, letterSpacing: 3, color: "var(--gold)", lineHeight: 1 }}>
                BET SCOUT PRO
              </div>
              <div style={{ fontFamily: "var(--font-mono)", fontSize: 10, color: "var(--text3)", letterSpacing: 1, textTransform: "uppercase", marginTop: 3 }}>
                AI Intelligence · Live Web Scraping · Max 2.5 Odds
              </div>
            </div>
          </div>
        </div>

        {/* CONTROLS */}
        <div style={{ background: "var(--ink2)", border: "1px solid var(--wire2)", padding: 16, marginBottom: 20 }}>
          <div style={{ display: "flex", gap: 12, flexWrap: "wrap", marginBottom: 16 }}>
            <div style={{ flex: 1, minWidth: 150 }}>
              <Label>Sport</Label>
              <select value={sport} onChange={e => setSport(e.target.value)} style={selectStyle}>
                {SPORTS.map(s => <option key={s}>{s}</option>)}
              </select>
            </div>
            <div style={{ flex: 1, minWidth: 150 }}>
              <Label>League</Label>
              <select value={league} onChange={e => setLeague(e.target.value)} style={selectStyle}>
                {LEAGUES.map(l => <option key={l}>{l}</option>)}
              </select>
            </div>
          </div>

          <div style={{ marginBottom: 16 }}>
            <Label>Risk Tolerance: <span style={{ color: "var(--gold)" }}>{TOLERANCE_LABELS[tolerance]}</span></Label>
            <div style={{ display: "flex", gap: 6, marginTop: 8 }}>
              {[1, 2, 3, 4, 5].map(v => (
                <button key={v} onClick={() => setTolerance(v)} style={{
                  flex: 1, padding: "8px 4px",
                  background: tolerance === v ? "var(--gold)" : "var(--ink3)",
                  border: `1px solid ${tolerance === v ? "var(--gold)" : "var(--wire2)"}`,
                  color: tolerance === v ? "#060a0f" : "var(--text3)",
                  fontFamily: "var(--font-head)", fontSize: 16, letterSpacing: 1,
                }}>
                  {v}
                </button>
              ))}
            </div>
            <div style={{ display: "flex", justifyContent: "space-between", fontFamily: "var(--font-mono)", fontSize: 9, color: "var(--text3)", marginTop: 4 }}>
              <span>Safe</span><span>High Risk</span>
            </div>
          </div>

          <button onClick={scout} disabled={loading} style={{
            width: "100%", background: loading ? "var(--wire2)" : "var(--gold)",
            color: loading ? "var(--text3)" : "#060a0f", border: "none",
            padding: "14px 0", fontFamily: "var(--font-head)", fontSize: 20, letterSpacing: 3,
            display: "flex", alignItems: "center", justifyContent: "center", gap: 12,
          }}>
            {loading ? <><Spinner size={18} /> SCOUTING THE WEB...</> : "🔍 SCOUT PREDICTIONS"}
          </button>
        </div>

        {/* STATUS */}
        {(loading || status) && !error && (
          <div style={{ display: "flex", gap: 10, alignItems: "center", padding: "10px 14px", background: "var(--ink2)", border: "1px solid var(--wire2)", marginBottom: 16, fontFamily: "var(--font-mono)", fontSize: 12, color: "var(--gold)" }}>
            {loading && <Spinner />}
            {!loading && <span style={{ color: "var(--lime)" }}>●</span>}
            {status}
          </div>
        )}
        {error && (
          <div style={{ padding: "10px 14px", background: "var(--red2)", border: "1px solid var(--red)", marginBottom: 16, fontFamily: "var(--font-mono)", fontSize: 12, color: "#fca5a5" }}>
            ⚠ {error}
          </div>
        )}

        {/* TABS */}
        {(picks.length > 0 || tab === "upload") && (
          <div style={{ display: "flex", borderBottom: "1px solid var(--wire)", marginBottom: 20, gap: 0 }}>
            {[["scout", `🔎 Scouted (${picks.length})`], ["slip", `🎫 Slip (${slip.length})`], ["upload", "📸 Upload"]].map(([key, label]) => (
              <button key={key} onClick={() => setTab(key)} style={{
                padding: "10px 18px", background: "none", border: "none",
                borderBottom: `2px solid ${tab === key ? "var(--gold)" : "transparent"}`,
                color: tab === key ? "var(--gold)" : "var(--text3)",
                fontFamily: "var(--font-mono)", fontSize: 12, textTransform: "uppercase", letterSpacing: 1,
                marginBottom: -1,
              }}>{label}</button>
            ))}
          </div>
        )}

        {/* UPLOAD TAB always accessible */}
        {tab === "upload" && (
          <UploadPanel tolerance={tolerance} onAddPick={p => { addToSlip(p); setTab("slip"); }} />
        )}

        {/* SCOUTED PICKS */}
        {tab === "scout" && picks.length > 0 && (
          <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
            {picks.map((p, i) => (
              <div key={p.id || i} style={{ position: "relative" }}>
                <PickCard pick={p} index={i} onResearch={setResearching} inSlip={inSlipIds.has(p.id)} />
                {!inSlipIds.has(p.id) && (
                  <button
                    onClick={() => addToSlip(p)}
                    style={{
                      position: "absolute", bottom: 14, right: 14,
                      background: "var(--gold)", color: "#060a0f", border: "none",
                      padding: "5px 12px", fontFamily: "var(--font-head)", fontSize: 13, letterSpacing: 1,
                      zIndex: 2,
                    }}
                    onClick={e => { e.stopPropagation(); addToSlip(p); }}
                  >+ ADD TO SLIP</button>
                )}
                {inSlipIds.has(p.id) && (
                  <div style={{ position: "absolute", bottom: 14, right: 14, fontFamily: "var(--font-mono)", fontSize: 10, color: "var(--lime)", background: "var(--lime2)", padding: "5px 10px", border: "1px solid var(--lime)" }}>
                    ✓ IN SLIP
                  </div>
                )}
              </div>
            ))}
          </div>
        )}

        {/* SLIP TAB */}
        {tab === "slip" && (
          slip.length === 0
            ? <div style={{ textAlign: "center", padding: "48px 20px", color: "var(--text3)", fontFamily: "var(--font-mono)", fontSize: 13 }}>
                No picks in slip yet. Scout predictions or upload screenshots.
              </div>
            : <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
                {slip.map((p, i) => (
                  <PickCard key={p.id} pick={p} index={i} onResearch={setResearching} onRemove={removeFromSlip} inSlip />
                ))}
              </div>
        )}

        {/* ALWAYS SHOW BET SLIP SUMMARY AT BOTTOM */}
        {slip.length > 0 && (
          <BetSlip picks={slip} onResearch={setResearching} onRemove={removeFromSlip} stake={stake} onStakeChange={setStake} />
        )}

        {/* UPLOAD TAB ALWAYS ACCESSIBLE WHEN NO PICKS */}
        {picks.length === 0 && tab !== "upload" && (
          <div style={{ textAlign: "center", padding: "32px 20px", color: "var(--text3)" }}>
            <div style={{ fontFamily: "var(--font-head)", fontSize: 22, letterSpacing: 2, color: "var(--wire2)", marginBottom: 12 }}>
              READY TO SCOUT
            </div>
            <div style={{ fontFamily: "var(--font-mono)", fontSize: 12, marginBottom: 20 }}>
              Set your filters above and hit Scout, or<br />upload screenshots from social media below.
            </div>
            <button onClick={() => setTab("upload")} style={{
              background: "none", border: "1px solid var(--wire2)", color: "var(--text3)",
              padding: "10px 20px", fontFamily: "var(--font-head)", fontSize: 15, letterSpacing: 2,
            }}>📸 UPLOAD SCREENSHOTS</button>
          </div>
        )}
      </div>
    </>
  );
}

const selectStyle = {
  width: "100%", background: "var(--ink)", border: "1px solid var(--wire2)", color: "var(--text)",
  padding: "8px 12px", fontSize: 13, marginTop: 4, outline: "none",
};

function Label({ children }) {
  return <div style={{ fontFamily: "var(--font-mono)", fontSize: 10, color: "var(--text3)", textTransform: "uppercase", letterSpacing: 1 }}>{children}</div>;
}
